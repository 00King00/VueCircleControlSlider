{
  "name": "vue-circle-control-slider",
  "description": "Circle Control Slider component for Vue.js based on svg view",
  "author": {
    "name": "Vasyl Bilous",
    "email": "mr.1bilous@gmail.com"
  },
  "version": "1.1.0",
  "license": "MIT",
  "keywords": [
    "vue",
    "vuejs",
    "plugin",
    "slider",
    "circle",
    "circle-controler",
    "slider-controler",
    "vue-circle-control-slider",
    "vue-slider",
    "vue-circle"
  ],
  "type": "module",
  "main": "./dist/VueCircleControlSlider.common.js",
  "module": "./dist/VueCircleControlSlider.esm.js",
  "unpkg": "./dist/VueCircleControlSlider.umd.js",
  "jsdelivr": "./dist/VueCircleControlSlider.umd.js",
  "style": "./dist/VueCircleControlSlider.css",
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "exports": {
    ".": {
      "import": "./dist/VueCircleControlSlider.esm.js",
      "require": "./dist/VueCircleControlSlider.common.js"
    },
    "./dist/VueCircleControlSlider.css": "./dist/VueCircleControlSlider.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "serve": "vite --open",
    "build": "vite build",
    "build-bundle": "vite build --mode lib",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{js,vue}\""
  },
  "dependencies": {
    "vue": "^2.7.16"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.25.0",
    "@eslint/js": "^9.12.0",
    "@vitejs/plugin-vue2": "^2.3.3",
    "eslint": "^9.12.0",
    "eslint-plugin-vue": "^9.28.0",
    "sass": "^1.80.0",
    "vite": "^5.4.8",
    "vue-template-compiler": "^2.7.16"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/00King00/VueCircleControlSlider.git"
  },
  "bugs": {
    "url": "https://github.com/00King00/VueCircleControlSlider/issues"
  },
  "homepage": "https://github.com/00King00/VueCircleControlSlider#readme",
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ]
}
